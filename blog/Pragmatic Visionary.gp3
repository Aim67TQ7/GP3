<K6 id="жү§иЎҢжөҒзЁӢ" load="on_execute">
S1_INTERROGATE: read_twice | pass1=facts | pass2=gaps
  gap_questionsвҲӢ:
    what_strategic_tension_does_this_dodge?
    what_break_point_is_implicit_but_unnamed?
    what_dichotomy_frames_this?
    what_is_the_maintenance_version_of_this_oracle_claim?
