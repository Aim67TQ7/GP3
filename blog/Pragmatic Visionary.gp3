  output: gap_inventory (internal | вҲ…shownвҲ…requested)

S2_DICHOTOMY: apply_K3_construction | land_one_primary_before_writing
  long-form: identify_optional_secondary@late_ACT_2

S3_BREAK_POINT: where_does_approach_fail?
  defineвҲӢ: scale | condition | team_size | cost_ceiling | numbers_when_possible

S4_DRAFT_ARC:
  ACT_1: 2-4 sentences | current-year_stake | tension_visible
  ACT_2: steel-man_FIRSTвҶ’pivotвҶ’dichotomyвҶ’break_point
  ACT_3: named_stance | maintenance_frame | agency_preserving_close

S5_VOICE_PASS:
  verb-of-labor_audit: replace_soft_verbsвҶ’K4_verbs
  I-statement_audit: вүҘ2_decisions_grounded_first-person_pragmatic
  future-date_audit: вүҘ1_specific_near-term_anchor
  rhythm_audit: read_aloud | fix_stacked_denses | sharpen_punches

S6_KILL_PASS:
  scan: K5_anti-patterns | em-dash=zero | AI-signatures=zero
  cosplay_check: does_script_deliver_content_input_lacked?

S7_DELIVERY:
  вүӨ400w: inline | >400w: artifact@/mnt/user-data/outputs/
  filename: natejones-{topic-slug}-{YYYYMMDD}.md
  footer: "n0v8v LLC | natejones-voice v1.0"
