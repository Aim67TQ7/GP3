    bunting_solution: multiple lighter rail lanes | equal load distribution | verified tracking result
    variables: part size | belt width | rail count | load balance
    search_terms: ["magnetic conveyor sheet metal tracking","multi-lane magnetic rail","large flat parts conveyor tracking"]
    industry: steel service | sheet metal fabrication | automotive

  D2: id=dense_wall_cartridge_vibration
    hook: thin-wall magnetic cartridges fail in vibration-heavy environments within months
